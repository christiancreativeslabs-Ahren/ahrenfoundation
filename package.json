{
  "name": "ahrenfoundation",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "db:dev:migrate": "tsx ./db/migrations/migrate.ts dev",
    "db:dev:generate": "drizzle-kit generate --config ./db/migrations/drizzle-dev.config.ts",
    "db:staging:migrate": "tsx ./db/migrations/migrate.ts staging",
    "db:staging:generate": "drizzle-kit generate --config ./db/migrations/drizzle-staging.config.ts",
    "db:prod:migrate": "tsx ./db/migrations/migrate.ts prod",
    "db:prod:generate": "drizzle-kit generate --config ./db/migrations/drizzle-prod.config.ts",
    "db:seed:admin": "tsx ./db/seeds/admin-auth-user.ts",
    "lint": "eslint",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@neondatabase/serverless": "^1.1.0",
    "@paralleldrive/cuid2": "^3.3.0",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-tabs": "^1.1.14",
    "better-auth": "^1.6.16",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.17.0",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "bufferutil": "^4.1.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^6"
  },
  "packageManager": "pnpm@11.5.3"
}
